RewriteEngine On

# ── CAREERS API: Route /api/careers/* → careers/index.php ──────
# Note: Apache will handle this via the sub-directory's own .htaccess
# when requests reach php_backend/careers/

# Route /api/contact to contact.php
RewriteRule ^contact/?$ contact.php [L]

# Route /api/send-otp to otp.php?action=send-otp
RewriteRule ^send-otp/?$ otp.php?action=send-otp [L,QSA]

# Route /api/verify-otp-only to otp.php?action=verify-otp-only
RewriteRule ^verify-otp-only/?$ otp.php?action=verify-otp-only [L,QSA]

# Route /api/verify-otp-and-lead to otp.php?action=verify-otp-and-lead
RewriteRule ^verify-otp-and-lead/?$ otp.php?action=verify-otp-and-lead [L,QSA]

# Route /api/health to otp.php?action=health
RewriteRule ^health/?$ otp.php?action=health [L,QSA]
